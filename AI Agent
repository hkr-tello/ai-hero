        "%%writefile /content/vscode_agent_app/app.py\n",
        "\n",
        "import streamlit as st\n",
        "import asyncio\n",
        "import json\n",
        "from groq import Groq\n",
        "import ingest\n",
        "\n",
        "# --- Page config ---\n",
        "st.set_page_config(page_title=\"VS Code Docs AI Assistant\", page_icon=\"рҹӨ–\", layout=\"centered\")\n",
        "\n",
        "# --- Initialize (cached) ---\n",
        "@st.cache_resource\n",
        "def init_app():\n",
        "    repo_owner = \"microsoft\"\n",
        "    repo_name = \"vscode-docs\"\n",
        "    with st.spinner(\"рҹ“Ҙ Downloading and indexing VS Code docs...\"):\n",
        "        index, chunks = ingest.index_data(repo_owner, repo_name)\n",
        "    client = Groq()\n",
        "    return index, client, len(chunks)\n",
        "\n",
        "index, client, num_chunks = init_app()\n",
        "\n",
        "SYSTEM_PROMPT = \"\"\"You are a helpful VS Code documentation assistant.\n",
        "\n",
        "Answer the user's question based ONLY on the search results provided below.\n",
        "- Give a clear, well-structured answer.\n",
        "- Cite the source document title when relevant.\n",
        "- If the search results don't cover the question, say so honestly.\n",
        "- Never make up information that isn't in the search results.\n",
        "\"\"\"\n",
        "\n",
        "def search_and_answer(question):\n",
        "    \"\"\"Search docs, then ask LLM to answer based on results.\"\"\"\n",
        "    # Step 1: Search (we do this ourselves вҖ” no tool calling needed)\n",
        "    results = index.search(question, num_results=5)\n",
        "\n",
        "    # Step 2: Format search results as context\n",
        "    context_parts = []\n",
        "    for i, r in enumerate(results):\n",
        "        title = r.get('title', 'Untitled')\n",
        "        filename = r.get('filename', '')\n",
        "        section = r.get('section', r.get('content', ''))[:800]\n",
        "        context_parts.append(f\"[{i+1}] Title: {title} | File: {filename}\\n{section}\")\n",
        "\n",
        "    context = \"\\n\\n---\\n\\n\".join(context_parts)\n",
        "\n",
        "    # Step 3: Send to LLM with context\n",
        "    user_message = f\"\"\"SEARCH RESULTS:\n",
        "{context}\n",
        "\n",
        "USER QUESTION: {question}\n",
        "\n",
        "Please answer based on the search results above.\"\"\"\n",
        "\n",
        "    response = client.chat.completions.create(\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "        messages=[\n",
        "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
        "            {\"role\": \"user\", \"content\": user_message}\n",
        "        ],\n",
        "        max_tokens=1000,\n",
        "    )\n",
        "\n",
        "    return response.choices[0].message.content\n",
        "\n",
        "\n",
        "# --- UI ---\n",
        "st.title(\"рҹӨ– VS Code Docs Assistant\")\n",
        "st.caption(f\"Ask me anything about VS Code! Searching {num_chunks} indexed doc sections.\")\n",
        "\n",
        "if \"messages\" not in st.session_state:\n",
        "    st.session_state.messages = []\n",
        "\n",
        "for msg in st.session_state.messages:\n",
        "    with st.chat_message(msg[\"role\"]):\n",
        "        st.markdown(msg[\"content\"])\n",
        "\n",
        "if prompt := st.chat_input(\"Ask about VS Code...\"):\n",
        "    st.session_state.messages.append({\"role\": \"user\", \"content\": prompt})\n",
        "    with st.chat_message(\"user\"):\n",
        "        st.markdown(prompt)\n",
        "\n",
        "    with st.chat_message(\"assistant\"):\n",
        "        with st.spinner(\"рҹ”Қ Searching docs and thinking...\"):\n",
        "            try:\n",
        "                answer = search_and_answer(prompt)\n",
        "                st.markdown(answer)\n",
        "            except Exception as e:\n",
        "                answer = f\"вҡ пёҸ Error: {str(e)[:200]}. Please try again in a moment.\"\n",
        "                st.error(answer)\n",
        "\n",
        "    st.session_state.messages.append({\"role\": \"assistant\", \"content\": answer})"
