          "text": [
            "=== CONTENT SIZE ANALYSIS ===\n",
            "Total docs         : 781\n",
            "Average length     : 15,496 chars\n",
            "Median length      : 8,463 chars\n",
            "Max length         : 99,920 chars\n",
