        "%%writefile /content/vscode_agent_app/eval/evaluation.py\n",
        "\n",
        "\"\"\"LLM-as-a-Judge evaluation for the VS Code docs agent.\"\"\"\n",
        "\n",
        "import json\n",
        "from groq import Groq\n",
        "\n",
        "\n",
        "EVALUATION_PROMPT = \"\"\"\n",
        "Evaluate the AI agent's answer using this checklist.\n",
        "For each item, output true/false with a short justification.\n",
        "\n",
        "Checklist:\n",
        "- instructions_follow: The agent followed the system instructions\n",
        "- answer_relevant: The response directly addresses the user's question\n",
        "- answer_clear: The answer is clear and well-structured\n",
        "- completeness: The response covers all key aspects\n",
        "- tool_call_search: The agent used search before answering\n",
        "\n",
        "Return ONLY valid JSON:\n",
        "{\n",
        "  \"checklist\": [\n",
        "    {\"check_name\": \"...\", \"justification\": \"...\", \"check_pass\": true/false},\n",
        "    ...\n",
        "  ],\n",
        "  \"summary\": \"Overall assessment.\"\n",
        "}\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "def evaluate_interaction(question, answer, instructions, log_simplified=\"\"):\n",
        "    \"\"\"Run LLM-as-a-Judge on a single interaction.\"\"\"\n",
        "    client = Groq()\n",
        "\n",
        "    user_prompt = f\"\"\"\n",
        "<INSTRUCTIONS>{instructions}</INSTRUCTIONS>\n",
        "<QUESTION>{question}</QUESTION>\n",
        "<ANSWER>{answer}</ANSWER>\n",
        "<LOG>{log_simplified}</LOG>\n",
        "\"\"\"\n",
        "\n",
        "    response = client.chat.completions.create(\n",
        "        model=\"llama-3.1-8b-instant\",\n",
        "        messages=[\n",
        "            {\"role\": \"system\", \"content\": EVALUATION_PROMPT},\n",
        "            {\"role\": \"user\", \"content\": user_prompt}\n",
        "        ],\n",
        "        max_tokens=800,\n",
        "    )\n",
        "\n",
        "    raw = response.choices[0].message.content\n",
        "    raw = raw.strip().removeprefix(\"```json\").removeprefix(\"```\").removesuffix(\"```\").strip()\n",
        "\n",
        "    try:\n",
        "        return json.loads(raw)\n",
        "    except json.JSONDecodeError:\n",
        "        return None\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    print(\"Run this from the evaluation notebook.\")"
