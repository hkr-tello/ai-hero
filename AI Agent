        "%%writefile /content/vscode_agent_app/eval/data_gen.py\n",
        "\n",
        "\"\"\"Generate test questions from VS Code documentation chunks.\"\"\"\n",
        "\n",
        "import json\n",
        "import random\n",
        "from groq import Groq\n",
        "\n",
        "\n",
        "def generate_questions(chunks, n_samples=10):\n",
        "    \"\"\"Sample chunks and generate realistic test questions.\"\"\"\n",
        "    client = Groq()\n",
        "    sample = random.sample(chunks, min(n_samples, len(chunks)))\n",
        "    sample_texts = [c.get('section', c.get('content', ''))[:500] for c in sample]\n",
        "\n",
        "    prompt = \"\"\"Based on the following VS Code documentation excerpts,\n",
        "generate one realistic question per excerpt that a developer might ask.\n",
        "Return ONLY a JSON array of strings.\n",
        "\n",
        "Documentation excerpts:\n",
        "\"\"\"\n",
        "\n",
        "    response = client.chat.completions.create(\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "        messages=[\n",
        "            {\"role\": \"system\", \"content\": \"Return only valid JSON.\"},\n",
        "            {\"role\": \"user\", \"content\": prompt + json.dumps(sample_texts)}\n",
        "        ],\n",
        "        max_tokens=1000,\n",
        "    )\n",
        "\n",
        "    raw = response.choices[0].message.content\n",
        "    raw = raw.strip().removeprefix(\"```json\").removeprefix(\"```\").removesuffix(\"```\").strip()\n",
        "    return json.loads(raw)\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    print(\"Run this from the evaluation notebook with chunks loaded.\")"
