        "\n",
        "# Text index\n",
        "text_index = Index(\n",
        "    text_fields=['section', 'title', 'filename'],\n",
        "    keyword_fields=[]\n",
        ")\n",
        "text_index.fit(final_chunks)\n",
        "print(f'✅ Text index built — {len(final_chunks)} chunks')\n",
        "\n",
        "# Vector index\n",
        "vector_index = VectorSearch()\n",
        "vector_index.fit(vscode_embeddings, final_chunks)\n",
        "print(f'✅ Vector index built — {vscode_embeddings.shape}')"
