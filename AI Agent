        "from typing import List, Any\n",
        "\n",
        "def text_search(query: str) -> List[Any]:\n",
        "    \"\"\"\n",
        "    Perform a keyword-based text search on VS Code documentation.\n",
        "\n",
        "    Args:\n",
        "        query: The search query string to look up in VS Code docs.\n",
        "\n",
        "    Returns:\n",
        "        A list of up to 5 matching documentation sections.\n",
        "    \"\"\"\n",
        "    return text_index.search(query, num_results=5)\n",
        "\n",
        "def vector_search(query: str) -> List[Any]:\n",
        "    \"\"\"\n",
        "    Perform a semantic (meaning-based) search on VS Code documentation.\n",
        "    Use this when the user's question uses different words than the docs.\n",
        "\n",
        "    Args:\n",
        "        query: The search query string for semantic matching.\n",
        "\n",
        "    Returns:\n",
        "        A list of up to 5 semantically similar documentation sections.\n",
        "    \"\"\"\n",
        "    q_vec = embedding_model.encode(query)\n",
        "    return vector_index.search(q_vec, num_results=5)\n",
        "\n",
        "# Quick test\n",
        "print(f\"✅ text_search works: {len(text_search('keyboard shortcuts'))} results\")\n",
        "print(f\"✅ vector_search works: {len(vector_search('remap keys'))} results\")"
